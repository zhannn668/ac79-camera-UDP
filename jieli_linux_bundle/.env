# 杰理设备 IP 与端口
DEVICE_IP=192.168.1.1
UDP_PORT=2224
CTP_PORT=3333
HEARTBEAT=10

# 打开杰理实时流的参数
OPEN_W=640
OPEN_H=480
OPEN_FPS=20
OPEN_RATE=8000
OPEN_FMT=0

# 显示到 LCD
DISPLAY_NUM=:0.0
DISPLAY_W=1280
DISPLAY_H=800
SHOW_WINDOW=1

# 模型路径
MODEL_PATH=/home/elf/work/jieli_linux_bundle/model/best.rknn
LABELS_PATH=/home/elf/work/jieli_linux_bundle/model/labels.txt

# 推理阈值
OBJ_THRESH=0.25
NMS_THRESH=0.45


# 可选项：如果你的模型输入需要 BGR，则改成 1
BGR_INPUT=0

# 可选项：只用单核 NPU
SINGLE_CORE=0

# 可选项：打印详细推理日志
VERBOSE_INFER=0
